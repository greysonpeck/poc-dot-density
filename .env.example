# Google Maps API key with both "Maps JavaScript API" and "Directions API" enabled.
# Directions API is used to route generated waypoints along real roads.
# https://console.cloud.google.com/google/maps-apis/credentials
VITE_GOOGLE_MAPS_API_KEY=

# Map ID required for Advanced Markers (vector rendering).
# Local dev: Google's public demo id works with no console setup: DEMO_MAP_ID
# Anything beyond local prototyping: create your own at
# https://console.cloud.google.com/google/maps-apis/studio/maps
VITE_GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID
